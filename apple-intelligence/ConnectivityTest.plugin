#!name=Apple Intelligence 连通性测试
#!desc=测试「Apple Intelligence 分流」插件是否真正生效：并发检测 6 个苹果 AI 域名能否通过代理访问，结果显示在 Loon 面板（Panel）页。\n\n【怎么用】\n1. 先安装「Apple Intelligence 分流」主插件并选好代理节点组\n2. 安装本插件\n3. 进入 Loon → 面板（Panel）页 → 点「Apple Intelligence 连通性」面板右上角的刷新按钮\n\n【结果说明】\n• ✅ HTTP 2xx/4xx → 域名可达，代理链路正常（4xx 是苹果服务器要求客户端凭证，不是网络错误）\n• ❌ 连接超时 / 拒绝 → 代理未生效或节点挂了，检查节点选择\n\n【常见连接失败原因】\n1. 主插件里的策略（PROXY）没有指定节点组 → 点主插件设置页指派\n2. 节点本身连不到这些域名 → 换节点或换落地\n3. 节点不转发 UDP → 打开主插件「禁用苹果智能的 QUIC」开关强制走 TCP
#!author=ccfco[https://github.com/ccfco]
#!homepage=https://github.com/ccfco/loon-plugins
#!icon=https://cdn.jsdelivr.net/gh/ccfco/loon-plugins@main/apple-intelligence/icon.png
#!tag=Apple, Apple Intelligence, 测试, 连通性

[Script]
generic script-path=https://cdn.jsdelivr.net/gh/ccfco/loon-plugins@main/apple-intelligence/connectivity-test.js,tag=Apple Intelligence 连通性测试,timeout=15

[Panel]
Apple Intelligence 连通性=type=script,script-path=https://cdn.jsdelivr.net/gh/ccfco/loon-plugins@main/apple-intelligence/connectivity-test.js,update-interval=0
